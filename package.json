{
  "name": "@saper-vedere/date-range-picker",
  "version": "0.1.2",
  "description": "Vue 3 + TypeScript date range picker with two-month calendar, drag-to-adjust, optional input mode with popover, presets, theming via CSS custom properties, and full slot customisation.",
  "keywords": [
    "vue",
    "vue3",
    "typescript",
    "date-picker",
    "date-range-picker",
    "calendar",
    "datepicker",
    "component"
  ],
  "license": "MIT",
  "author": "Saper Vedere",
  "homepage": "https://github.com/Saper-Vedere-EU/date-range-picker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saper-Vedere-EU/date-range-picker.git"
  },
  "bugs": {
    "url": "https://github.com/Saper-Vedere-EU/date-range-picker/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/date-range-picker.cjs",
  "module": "./dist/date-range-picker.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/date-range-picker.js",
      "require": "./dist/date-range-picker.cjs"
    },
    "./style.css": "./dist/date-range-picker.css"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "vue-tsc -b --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/compiler-dom": "^3.5.33",
    "@vue/server-renderer": "^3.5.33",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.7"
  }
}
